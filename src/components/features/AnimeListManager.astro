<script is:inline data-swup-ignore-script>
	(() => {
		const ITEMS_PER_PAGE = 12;
		const STATUS_META = {
			watching: {
				label: "Watching",
				color: "bg-yellow-500",
			},
			completed: {
				label: "Completed",
				color: "bg-green-500",
			},
			plan_to_watch: {
				label: "Plan to Watch",
				color: "bg-blue-500",
			},
		};

		function escapeHtml(value) {
			return String(value ?? "")
				.replaceAll("&", "&amp;")
				.replaceAll("<", "&lt;")
				.replaceAll(">", "&gt;")
				.replaceAll('"', "&quot;")
				.replaceAll("'", "&#039;");
		}

		function formatYear(date) {
			return date ? date.substring(0, 4) : "Unknown";
		}

		function formatEpisodes(item) {
			const watched = item.list_status?.num_episodes_watched ?? 0;
			const total = item.node.num_episodes;
			if (total) return `${watched}/${total} eps`;
			return watched ? `${watched} eps` : "";
		}

		function getPoster(item) {
			return item.node.main_picture?.large || item.node.main_picture?.medium || "";
		}

		function buttonClass(isActive) {
			const base = "btn-regular px-3 py-1.5 rounded-lg transition-colors duration-200 text-sm font-medium";
			if (isActive) return `${base} bg-(--primary) text-white hover:bg-(--primary)`;
			return `${base} bg-(--btn-regular-bg) text-(--btn-content) hover:bg-(--btn-regular-bg-hover)`;
		}

		function initAnimePage() {
			const app = document.getElementById("anime-app");
			if (!app || app.dataset.animeInitialized === "true") return;

			const filtersEl = document.getElementById("anime-filters");
			const gridEl = document.getElementById("anime-grid");
			const paginationEl = document.getElementById("anime-pagination");
			const emptyEl = document.getElementById("anime-empty");
			const emptyMessageEl = document.getElementById("anime-empty-message");
			const updatedAtEl = document.getElementById("anime-updated-at");

			if (
				!filtersEl ||
				!gridEl ||
				!paginationEl ||
				!emptyEl ||
				!emptyMessageEl ||
				!updatedAtEl
			) {
				return;
			}

			app.dataset.animeInitialized = "true";

			let animeItems = [];
			let activeFilter = "all";
			let currentPage = 1;
			let statuses = ["watching", "completed", "plan_to_watch"];

			try {
				statuses = JSON.parse(app.dataset.statuses || "[]");
				if (!Array.isArray(statuses) || statuses.length === 0) {
					statuses = ["watching", "completed", "plan_to_watch"];
				}
			} catch {
				statuses = ["watching", "completed", "plan_to_watch"];
			}

			const animeApiUrl = app.dataset.apiUrl || "/api/anime.json";

			function getFilteredItems() {
				if (activeFilter === "all") return animeItems;
				return animeItems.filter((item) => item.list_status?.status === activeFilter);
			}

			function renderFilters() {
				const counts = animeItems.reduce((acc, item) => {
					const status = item.list_status?.status || "unknown";
					acc[status] = (acc[status] || 0) + 1;
					return acc;
				}, {});
				const filterList = [
					{ value: "all", label: "All", count: animeItems.length },
					...statuses
						.map((status) => ({
							value: status,
							label: STATUS_META[status]?.label || status,
							count: counts[status] || 0,
						}))
						.filter((filter) => filter.count > 0),
				];

				filtersEl.innerHTML = filterList
					.map(
						(filter) => `<button class="${buttonClass(filter.value === activeFilter)}" data-anime-filter="${escapeHtml(filter.value)}" type="button">
							${escapeHtml(filter.label)} <span class="ml-1">(${filter.count})</span>
						</button>`,
					)
					.join("");

				filtersEl.querySelectorAll("[data-anime-filter]").forEach((button) => {
					button.addEventListener("click", () => {
						activeFilter = button.dataset.animeFilter || "all";
						currentPage = 1;
						render();
					});
				});
			}

			function renderGrid() {
				const visibleItems = getFilteredItems();
				const start = (currentPage - 1) * ITEMS_PER_PAGE;
				const pageItems = visibleItems.slice(start, start + ITEMS_PER_PAGE);

				gridEl.innerHTML = pageItems
					.map((item) => {
						const status = item.list_status?.status || "unknown";
						const statusMeta = STATUS_META[status] || {
							label: status,
							color: "bg-gray-500",
						};
						const title = item.node.title;
						const poster = getPoster(item);
						const score = item.list_status?.score || item.node.mean;
						const episodes = formatEpisodes(item);
						const genres = (item.node.genres || []).slice(0, 3);

						return `<a
							href="https://myanimelist.net/anime/${item.node.id}"
							target="_blank"
							rel="noopener noreferrer nofollow"
							class="group relative overflow-hidden rounded-xl transition-all duration-300 hover:shadow-lg hover:scale-[1.02] block bg-(--btn-regular-bg)"
						>
							<div class="aspect-2/3 relative overflow-hidden">
								${
									poster
										? `<img
											src="${escapeHtml(poster)}"
											alt="${escapeHtml(title)}"
											class="w-full h-full object-cover pointer-events-none transition-transform duration-500 group-hover:scale-105"
											loading="lazy"
											decoding="async"
										/>`
										: `<div class="w-full h-full bg-gray-200 dark:bg-gray-700 flex items-center justify-center text-gray-400 text-4xl">TV</div>`
								}
								<div class="absolute top-2 left-2 px-2 py-1 rounded-full text-xs text-white font-medium ${statusMeta.color}">
									${escapeHtml(statusMeta.label)}
								</div>
								${
									score
										? `<div class="absolute top-2 right-2 px-2 py-1 rounded-full text-xs text-white font-medium bg-black/50 backdrop-blur-sm">${escapeHtml(score)}</div>`
										: ""
								}
								<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
								<div class="absolute bottom-0 left-0 right-0 p-3">
									<h3 class="font-bold text-sm text-white line-clamp-2 drop-shadow-lg">
										${escapeHtml(title)}
									</h3>
									<div class="text-xs text-white/65 mt-1">
										${escapeHtml(formatYear(item.node.start_date))}
										${episodes ? ` · ${escapeHtml(episodes)}` : ""}
									</div>
									${
										genres.length > 0
											? `<div class="flex flex-wrap gap-1 mt-1.5">
												${genres
													.map(
														(genre) => `<span class="text-[0.6rem] px-1.5 py-0.5 rounded bg-white/20 text-white/90 backdrop-blur-sm">
															${escapeHtml(genre.name)}
														</span>`,
													)
													.join("")}
											</div>`
											: ""
									}
								</div>
							</div>
						</a>`;
					})
					.join("");
			}

			function renderPagination() {
				const totalItems = getFilteredItems().length;
				const totalPages = Math.max(Math.ceil(totalItems / ITEMS_PER_PAGE), 1);
				currentPage = Math.min(currentPage, totalPages);

				if (totalItems <= ITEMS_PER_PAGE) {
					paginationEl.innerHTML = "";
					return;
				}

				const pageButtons = Array.from({ length: totalPages }, (_, index) => {
					const page = index + 1;
					return `<button class="${buttonClass(page === currentPage)}" data-anime-page="${page}" type="button">${page}</button>`;
				}).join("");

				paginationEl.innerHTML = `
					<button class="${buttonClass(false)}" data-anime-page-prev type="button" ${currentPage === 1 ? "disabled" : ""}>Prev</button>
					${pageButtons}
					<button class="${buttonClass(false)}" data-anime-page-next type="button" ${currentPage === totalPages ? "disabled" : ""}>Next</button>
				`;

				paginationEl.querySelectorAll("[data-anime-page]").forEach((button) => {
					button.addEventListener("click", () => {
						currentPage = Number(button.dataset.animePage || "1");
						render();
					});
				});
				paginationEl.querySelector("[data-anime-page-prev]")?.addEventListener("click", () => {
					currentPage = Math.max(currentPage - 1, 1);
					render();
				});
				paginationEl.querySelector("[data-anime-page-next]")?.addEventListener("click", () => {
					currentPage = Math.min(currentPage + 1, totalPages);
					render();
				});
			}

			function render() {
				if (!animeItems.length) {
					filtersEl.innerHTML = "";
					gridEl.innerHTML = "";
					paginationEl.innerHTML = "";
					emptyEl.classList.remove("hidden");
					return;
				}

				emptyEl.classList.add("hidden");
				renderFilters();
				renderGrid();
				renderPagination();
			}

			fetch(animeApiUrl)
				.then(async (response) => {
					const payload = await response.json();
					if (!response.ok || !payload.configured) {
						throw new Error(payload.message || "MyAnimeList is not configured.");
					}
					animeItems = payload.items || [];
					const loadedAt = payload.updatedAt ? new Date(payload.updatedAt) : new Date();
					updatedAtEl.textContent = `Loaded from MyAnimeList at ${loadedAt.toLocaleString()}`;
					render();
				})
				.catch((error) => {
					console.error("[MAL] Failed to load anime list:", error);
					updatedAtEl.textContent = "Could not load MyAnimeList data.";
					emptyMessageEl.textContent =
						error?.message ||
						"Check that the MAL client ID is valid and that your anime list is public.";
					render();
				});
		}

		function scheduleAnimeInit() {
			initAnimePage();
			setTimeout(initAnimePage, 120);
		}

		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", scheduleAnimeInit);
		} else {
			scheduleAnimeInit();
		}

		document.addEventListener("astro:page-load", scheduleAnimeInit);
		document.addEventListener("swup:contentReplaced", scheduleAnimeInit);
		document.addEventListener("swup:content:replace", scheduleAnimeInit);
		document.addEventListener("swup:page:view", scheduleAnimeInit);
		document.addEventListener("swup:enable", scheduleAnimeInit);

		if (window.swup?.hooks) {
			window.swup.hooks.on("content:replace", scheduleAnimeInit);
			window.swup.hooks.on("page:view", scheduleAnimeInit);
		}
	})();
</script>
